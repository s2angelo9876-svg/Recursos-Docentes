# Copiar a .env y ajustar valores antes de desplegar en producción

JWT_SECRET=cambiar-por-un-secreto-seguro-en-produccion
PORT=5000
NODE_ENV=development

# Orígenes permitidos por CORS (producción + desarrollo local)
# En producción debe incluir el dominio de Vercel, separado por comas.
CORS_ORIGIN=https://recursos-docentes-aip.vercel.app,http://localhost:5173

# URL del backend para el frontend en producción (Vercel → Render)
# En desarrollo local déjalo vacío para usar el proxy de Vite.
VITE_API_URL=

# URL de conexión a PostgreSQL (Supabase Transaction Pooler)
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Credenciales de Supabase Storage
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Nombre del bucket de Supabase Storage (opcional, default: recursos-uploads)
# SUPABASE_STORAGE_BUCKET=recursos-uploads
