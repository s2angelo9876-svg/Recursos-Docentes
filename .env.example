# Copiar a .env y ajustar valores antes de desplegar en producción

JWT_SECRET=cambiar-por-un-secreto-seguro-en-produccion
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Ruta de la base de datos SQLite.
# En desarrollo usa ./db/innova.sqlite para mantener consistencia con Docker.
# Se usa solo si no está definida DATABASE_URL.
DB_PATH=./db/innova.sqlite

# URL de conexión a PostgreSQL (ej. Supabase).
# Si está definida, el servidor usará PostgreSQL en lugar de SQLite.
# Ejemplo: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DATABASE_URL=

# Credenciales de Supabase Storage (opcional).
# Si están definidas, los archivos subidos se almacenarán en Supabase Storage.
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
